BSMCP_BOOKSTACK_URL=https://your-bookstack-instance.com
BSMCP_ENCRYPTION_KEY=your-secret-key-at-least-32-characters-long
# Domain for OAuth redirects (just the domain, https:// is added automatically)
# Replaces the old BSMCP_PUBLIC_URL variable (full URL) — remove it if you had it set
BSMCP_PUBLIC_DOMAIN=bookstack-mcp.example.com
# Internal Docker-network domain (http:// is added automatically)
# BSMCP_INTERNAL_DOMAIN=bookstack-mcp
# BSMCP_HOST=0.0.0.0
# BSMCP_PORT=8080
# BSMCP_INSTANCE_NAME=My Knowledge Base
# BSMCP_INSTANCE_DESC=Personal knowledge base
# BSMCP_DB_PATH=/data/bookstack-mcp.db
# BSMCP_BACKUP_INTERVAL=24
# BSMCP_BACKUP_PATH=/data/backups

# Semantic search (optional — set to true to enable vector search)
# BSMCP_SEMANTIC_SEARCH=false
# Directory for ONNX model cache (BAAI/bge-large-en-v1.5, ~1.3GB)
# BSMCP_MODEL_PATH=/data/models
# Secret for BookStack webhook URL verification (constant-time compared)
# Configure in BookStack: Settings → Webhooks → URL = https://mcp-host/webhooks/bookstack?secret=YOUR_SECRET
# BSMCP_WEBHOOK_SECRET=your-webhook-secret
# Separate BookStack API token for background embedding pipeline
# BSMCP_EMBED_TOKEN_ID=your-embed-token-id
# BSMCP_EMBED_TOKEN_SECRET=your-embed-token-secret

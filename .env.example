# ============================================
# BookStack MCP v0.3.0 Configuration
# ============================================

# --- Database ---

# Backend: "sqlite" (default) or "postgres"
# BSMCP_DB_BACKEND=sqlite

# PostgreSQL connection string (required when BSMCP_DB_BACKEND=postgres)
# BSMCP_DATABASE_URL=postgres://bsmcp:changeme@postgres/bsmcp
# BSMCP_DB_PASSWORD=changeme  # used in docker-compose for postgres service

# SQLite database path (used when BSMCP_DB_BACKEND=sqlite)
# BSMCP_DB_PATH=/data/bookstack-mcp.db

# --- Server (required) ---

BSMCP_BOOKSTACK_URL=https://your-bookstack-instance.com
BSMCP_ENCRYPTION_KEY=your-secret-key-at-least-32-characters-long

# Domain for OAuth redirects (just the domain, https:// is added automatically)
BSMCP_PUBLIC_DOMAIN=bookstack-mcp.example.com

# --- Server (optional) ---

# Internal Docker-network domain (http:// is added automatically)
# BSMCP_INTERNAL_DOMAIN=bookstack-mcp
# BSMCP_HOST=0.0.0.0
# BSMCP_PORT=8080
# BSMCP_INSTANCE_NAME=My Knowledge Base
# BSMCP_INSTANCE_DESC=Personal knowledge base
# BSMCP_BACKUP_INTERVAL=24
# BSMCP_BACKUP_PATH=/data/backups
# PUID=1000
# PGID=1000

# --- Semantic Search ---

# Enable semantic vector search tools
# BSMCP_SEMANTIC_SEARCH=true

# URL of the embedder service (for query embedding)
# BSMCP_EMBEDDER_URL=http://bsmcp-embedder:8081

# Secret for BookStack webhook URL verification (constant-time compared)
# Configure in BookStack: Settings → Webhooks → URL = https://mcp-host/webhooks/bookstack?secret=YOUR_SECRET
# BSMCP_WEBHOOK_SECRET=your-webhook-secret

# --- Embedder ---

# Separate BookStack API token for background embedding pipeline
# This token should have read access to all content you want searchable
# BSMCP_EMBED_TOKEN_ID=your-embed-token-id
# BSMCP_EMBED_TOKEN_SECRET=your-embed-token-secret

# ONNX model cache directory (BAAI/bge-large-en-v1.5, ~1.3GB download)
# BSMCP_MODEL_PATH=/data/models
# BSMCP_EMBED_MODEL=BAAI/bge-large-en-v1.5

# Performance tuning
# BSMCP_EMBED_THREADS=0           # 0 = all available cores
# BSMCP_EMBED_BATCH_SIZE=32       # chunks per embedding batch
# BSMCP_EMBED_DELAY_MS=50         # ms between pages (API throttle)
# BSMCP_EMBED_POLL_INTERVAL=5     # seconds between job queue polls

# Embedder HTTP endpoint
# BSMCP_EMBED_HOST=0.0.0.0
# BSMCP_EMBED_PORT=8081

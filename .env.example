# ============================================
# BookStack MCP v0.5.3 Configuration
# ============================================

# --- Database ---

# Backend: "sqlite" (default) or "postgres"
# BSMCP_DB_BACKEND=sqlite

# PostgreSQL connection string (required when BSMCP_DB_BACKEND=postgres)
# Note: hostname must match the docker compose service name (bsmcp-postgres)
# BSMCP_DATABASE_URL=postgres://bsmcp:changeme@bsmcp-postgres/bsmcp
# BSMCP_DB_PASSWORD=changeme  # used in docker-compose for postgres service

# SQLite database path (used when BSMCP_DB_BACKEND=sqlite)
# BSMCP_DB_PATH=/data/bookstack-mcp.db

# --- Server (required) ---

BSMCP_BOOKSTACK_URL=https://your-bookstack-instance.com
BSMCP_ENCRYPTION_KEY=your-secret-key-at-least-32-characters-long

# Domain for OAuth redirects (just the domain, https:// is added automatically)
BSMCP_PUBLIC_DOMAIN=bookstack-mcp.example.com

# --- Server (optional) ---

# Internal Docker-network domain (http:// is added automatically)
# BSMCP_INTERNAL_DOMAIN=bsmcp-server
# BSMCP_HOST=0.0.0.0
# BSMCP_PORT=8080
# BSMCP_INSTANCE_NAME=My Knowledge Base
# BSMCP_INSTANCE_DESC=Personal knowledge base
# BSMCP_BACKUP_INTERVAL=24
# BSMCP_BACKUP_PATH=/data/backups
# PUID=1000
# PGID=1000

# Token TTLs (seconds)
# BSMCP_ACCESS_TOKEN_TTL=2592000    # 30 days (how long before token expires; refresh extends it)
# BSMCP_REFRESH_TOKEN_TTL=7776000   # 90 days (how long before user must re-enter API keys)

# --- Semantic Search ---

# Enable semantic vector search tools
# BSMCP_SEMANTIC_SEARCH=true

# URL of the embedder service (for query embedding)
# BSMCP_EMBEDDER_URL=http://bsmcp-embedder:8081

# Secret for BookStack webhook verification (constant-time compared, 16+ chars)
# Configure in BookStack: Settings > Webhooks
#   URL: https://mcp-host/webhooks/bookstack
#   Header: X-Webhook-Secret: YOUR_SECRET
# BSMCP_WEBHOOK_SECRET=your-webhook-secret

# --- Embedder ---

# Separate BookStack API token for background embedding pipeline
# This token should have read access to all content you want searchable
# BSMCP_EMBED_TOKEN_ID=your-embed-token-id
# BSMCP_EMBED_TOKEN_SECRET=your-embed-token-secret

# Embedding provider: "local" (default, ONNX/fastembed), "ollama", "openai"
# Changing provider or model auto-triggers a clean re-index on next startup
# BSMCP_EMBED_PROVIDER=local

# Local model settings (BSMCP_EMBED_PROVIDER=local)
# Supported: BAAI/bge-base-en-v1.5, BAAI/bge-large-en-v1.5, BAAI/bge-small-en-v1.5, embeddinggemma-300m
# BSMCP_MODEL_PATH=/data/models
# BSMCP_EMBED_MODEL=BAAI/bge-base-en-v1.5

# Ollama settings (BSMCP_EMBED_PROVIDER=ollama)
# BSMCP_EMBED_MODEL=nomic-embed-text
# BSMCP_EMBED_API_URL=http://localhost:11434
# BSMCP_EMBED_DIMS=768                # auto-detected if not set

# OpenAI settings (BSMCP_EMBED_PROVIDER=openai)
# BSMCP_EMBED_MODEL=text-embedding-3-small
# BSMCP_EMBED_API_KEY=your-openai-key
# BSMCP_EMBED_API_URL=https://api.openai.com  # or any OpenAI-compatible endpoint
# BSMCP_EMBED_DIMS=1536

# Performance tuning
# BSMCP_EMBED_CPUS=0              # Docker CPU limit (0 = unlimited, 2 = 2 cores)
# BSMCP_EMBED_THREADS=0           # 0 = all available cores (deprecated: use BSMCP_EMBED_CPUS instead)
# BSMCP_EMBED_BATCH_SIZE=32       # chunks per embedding batch
# BSMCP_EMBED_DELAY_MS=50         # ms between pages (API throttle)
# BSMCP_EMBED_ON_STARTUP=false    # true = auto-embed on startup, clean = wipe + re-embed
# BSMCP_EMBED_POLL_INTERVAL=5     # seconds between job queue polls
# BSMCP_EMBED_JOB_TIMEOUT=14400   # seconds before stuck jobs reset (default: 4 hours)

# Embedder HTTP endpoint
# BSMCP_EMBED_HOST=0.0.0.0
# BSMCP_EMBED_PORT=8081

# --- Instance Summary (optional) ---

# LLM provider for generating an AI summary of the knowledge base.
# The summary is included in MCP instructions so connecting AI assistants
# immediately understand what this BookStack is about and who uses it.
# Provider: "openrouter", "anthropic", "openai", "ollama"
# BSMCP_LLM_PROVIDER=openrouter
# BSMCP_LLM_API_KEY=your-api-key                # not needed for ollama
# BSMCP_LLM_MODEL=anthropic/claude-sonnet-4     # provider-specific model ID
# BSMCP_LLM_API_URL=https://openrouter.ai       # base URL (useful for ollama on different host)

# How often to regenerate the summary (hours). 0 = only on first startup.
# BSMCP_SUMMARY_INTERVAL=24

# BookStack API token for reading content during summary generation.
# Falls back to BSMCP_EMBED_TOKEN_ID/SECRET if not set.
# BSMCP_SUMMARY_TOKEN_ID=your-token-id
# BSMCP_SUMMARY_TOKEN_SECRET=your-token-secret
